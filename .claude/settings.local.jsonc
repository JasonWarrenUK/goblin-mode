{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "A Bash command just ran. Check the tool input from $ARGUMENTS.\n\nIf the command was a `git commit` (not git add, git status, etc.), check whether any of the committed files are inside the `commands/` directory.\n\nTo determine this, look at the commit output for file paths, or note if the commit message references commands.\n\nIf the commit DID include changes to `commands/`:\n- Respond with: {\"ok\": true, \"additionalContext\": \"REMINDER: Files in commands/ were just committed. You should update commands/README.md to reflect the current state of the commands directory. Check the existing README structure and ensure all commands are listed accurately.\"}\n\nIf the commit did NOT include changes to `commands/`, or if this was not a git commit command:\n- Respond with: {\"ok\": true}",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start-local.sh"
          }
        ]
      }
    ]
  },
  "outputStyle": "british-dev-goblin",
  "permissions": {
    "allow": [
      // MCP tools
      "mcp__mcp-sequentialthinking-tools__sequentialthinking_tools",

      // bash: file system (read-only or safe writes)
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(wc:*)",

      // bash: package managers & runtimes
      "Bash(bun:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",

      // bash: network (can make mutating requests — use with awareness)
      "Bash(curl:*)",

      // gh: read-only / inspection
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh repo view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",

      // gh: write (creates or mutates GitHub state)
      "Bash(gh issue create:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr edit:*)",

      // excluded (destructive — always require approval):
      //   gh issue close/delete
      //   gh pr close/merge
      //   gh repo delete
      //   gh release delete

      // git: read-only / inspection
      "Bash(git blame:*)",
      "Bash(git branch:*)",       // listing only — -D/-d still requires approval
      "Bash(git describe:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git remote:*)",
      "Bash(git show:*)",
      "Bash(git stash list:*)",
      "Bash(git status:*)",
      "Bash(git tag:*)",

      // git: write (recoverable)
      "Bash(git add:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git merge:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",         // non-force only — --force still requires approval
      "Bash(git rebase:*)",
      "Bash(git stash:*)",
      "Bash(git switch:*)",

      // excluded (destructive — always require approval):
      //   git branch -D / -d
      //   git clean -f
      //   git push --force / -f
      //   git reset --hard
      //   git restore .
    ]
  }
}
